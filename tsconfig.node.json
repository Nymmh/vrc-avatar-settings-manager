{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*", 
    "src/main/**/*", 
    "src/preload/**/*", 
    "src/services/**/*", 
    "src/types/**/*", 
    "src/ipc/**/*",
    "src/database/**/*", 
    "src/osc/**/*.ts", 
    "src/file/**/*.ts", 
    "src/helpers/**/*.ts",
    "src/webhooks/**/*.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["electron-vite/node"],
  }
}
